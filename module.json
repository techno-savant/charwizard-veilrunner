    { "name": "vr-origins",     "label": "Origins",      "path": "packs/vr-origins",     "type": "Item", "system": "Veilrunner-System" },
    { "name": "vr-backgrounds", "label": "Backgrounds",  "path": "packs/vr-backgrounds", "type": "Item", "system": "Veilrunner-System" },
    { "name": "vr-archetypes",  "label": "Archetypes",   "path": "packs/vr-archetypes",  "type": "Item", "system": "Veilrunner-System" },
    { "name": "vr-classes",     "label": "Classes",      "path": "packs/vr-classes",     "type": "Item", "system": "Veilrunner-System" },
    { "name": "vr-disciplines", "label": "Disciplines",  "path": "packs/vr-disciplines", "type": "Item", "system": "Veilrunner-System" },
